# Run from L2.V27/research/work/python:
# docker build -f ../../python/Dockerfile.naive -t lab2-python-naive .
FROM python:3.12-bookworm
WORKDIR /app
COPY . .
RUN python -m pip install --no-cache-dir -r requirements/backend.lock
EXPOSE 8080
CMD ["uvicorn", "spaceship.main:app", "--host", "0.0.0.0", "--port", "8080"]
